@using CSE325project.Client.Services
@using CSE325project.Shared
@using Microsoft.AspNetCore.Components.Forms
@page "/signup"
@inject UserService UserService
@inject NavigationManager Navigation


<PageTitle>Create Account</PageTitle>

<h1>Create Account</h1>

<div class="form-container">
    <EditForm Model="newUser" OnValidSubmit="HandleSignup">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label for="firstName">First Name</label>
            <InputText @bind-Value="newUser.FirstName" id="firstName" />
        </div>

        <div class="form-group">
            <label for="lastName">Last Name</label>
            <InputText @bind-Value="newUser.LastName" id="lastName" />
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <InputText @bind-Value="newUser.Email" id="email" type="email" />
        </div>

        <div class="form-group">
            <label for="role">Role</label>
            <InputText @bind-Value="newUser.Role" id="role" />
        </div>

        <button type="submit" disabled="@isLoading">
            @(isLoading ? "Creating..." : "Create Account")
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">@errorMessage</div>
        }
    </EditForm>

    <p>
        Already have an account? <a href="/login">Login here</a>
    </p>
</div>

@code {
    private User newUser = new() { Role = "student" };
    private bool isLoading = false;
    private string errorMessage = "";

    private async Task HandleSignup()
    {
        try
        {
            isLoading = true;
            errorMessage = "";
            newUser.UserId = Guid.NewGuid();
            newUser.CreatedAt = DateTime.UtcNow;

            await UserService.CreateUserAsync(newUser);
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating account: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}